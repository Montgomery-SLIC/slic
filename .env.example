# Django secret key - generate with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# PostgreSQL/PgAdmin connection details
DB_NAME=slic_django
DB_USER=slic
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# 32-byte hex key used to compute HMAC blind indexes for encrypted email lookups
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
BLIND_INDEX_KEY=

# Fernet symmetric key used to encrypt PII fields (email, name, institution, etc.)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# Google reCAPTCHA keys for the participant start page
# Obtained from https://www.google.com/recaptcha/admin
# Leave blank to disable the captcha (development only)
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

# Comma-separated list of hostnames Django will serve
ALLOWED_HOSTS=slic.shef.ac.uk

# Absolute paths for collected static files and uploaded media (audio, transcripts, etc)
# Staging:    MEDIA_ROOT=/srv/slic/staging/media
# Production: MEDIA_ROOT=/srv/slic/production/media
MEDIA_ROOT=/srv/slic/staging/media
# Staging:    STATIC_ROOT=/srv/slic/staging/staticfiles
# Production: STATIC_ROOT=/srv/slic/production/staticfiles
STATIC_ROOT=/srv/slic/staging/staticfiles

# SMTP settings for outbound email (password reset, error alerts)
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_USE_TLS=false
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Address Django uses as the From header when sending server error emails
SERVER_EMAIL=

# Recipient for Django server error emails (ADMINS setting)
ADMIN_NAME=
ADMIN_EMAIL=

# Recipient for bug reports submitted via the bug report form
BUG_REPORT_EMAIL=
